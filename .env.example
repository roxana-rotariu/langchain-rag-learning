# Secrets only. Non-secret settings live in config/settings.yaml.
#
# The project defaults to the LOCAL provider (Ollama + HuggingFace) — no keys
# needed. Set the keys below only if you switch `provider: anthropic` in
# config/settings.yaml (or set LLM_PROVIDER=anthropic).

# Anthropic — https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embeddings) — https://dashboard.voyageai.com/
# VOYAGE_API_KEY=pa-...

# Optional overrides for config/settings.yaml (uncomment to use):
# LLM_PROVIDER=local
# OLLAMA_URL=http://localhost:11434
# QDRANT_URL=http://localhost:6333
